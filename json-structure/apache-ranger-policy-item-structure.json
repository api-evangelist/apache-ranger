{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-ranger/refs/heads/main/json-structure/apache-ranger-policy-item-structure.json",
  "description": "Policy item defining access permissions",
  "type": "object",
  "properties": {
    "users": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Users granted access"
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Groups granted access"
    },
    "accesses": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/AccessType"
      }
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "name": "PolicyItem"
}