{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-ranger/refs/heads/main/json-schema/apache-ranger-policy-resource-schema.json",
  "title": "PolicyResource",
  "description": "Resource specification in a Ranger policy",
  "type": "object",
  "properties": {
    "values": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Resource values (paths, tables, etc.)"
    },
    "isRecursive": {
      "type": "boolean",
      "description": "Whether to apply recursively"
    },
    "isExcludes": {
      "type": "boolean",
      "description": "Whether this is an exclusion list"
    }
  }
}